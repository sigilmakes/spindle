{
  "name": "spindle",
  "version": "0.1.0",
  "description": "Agent orchestration extension for pi",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint-plan": "node bin/lint-plan.mjs"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.58.1",
    "@mariozechner/pi-ai": "^0.58.1",
    "@mariozechner/pi-coding-agent": "^0.58.1",
    "@mariozechner/pi-tui": "^0.58.1",
    "@sinclair/typebox": "^0.34.48",
    "mcporter": "^0.7.3"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "pi": {
    "extensions": [
      "./src"
    ],
    "skills": [
      "./skills"
    ]
  },
  "keywords": [
    "pi-package"
  ],
  "bin": {
    "spindle": "./bin/spindle.mjs",
    "lint-plan": "./bin/lint-plan.mjs"
  }
}
